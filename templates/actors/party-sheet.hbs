<form class="zut-sheet zut-party-sheet {{cssClass}}" autocomplete="off">
  <div class="zut-party-shell">
    <div class="zut-party-shell__grid">
      <section class="zut-sheet__section zut-party-header-panel">
        <div class="zut-party-header-panel__grid">
          <div class="zut-party-header-panel__portrait-slot">
            <button
              class="zut-portrait-button zut-sheet__portrait zut-party-header__portrait {{#if canEdit}}is-editable{{/if}}"
              type="button"
              data-edit-image="true"
              data-edit="img"
              title="{{localize "ZUT.Sheets.Common.Actions.EditPortrait"}}"
              aria-label="{{localize "ZUT.Sheets.Common.Actions.EditPortrait"}}"
              {{#unless canEdit}}disabled{{/unless}}
              >
              <img
                class="zut-sheet__portrait-image"
                src="{{actor.img}}"
                alt="{{actor.name}}"
              >
            </button>
          </div>

          <div class="zut-party-header-panel__content">
            <div class="zut-field">
              <div class="zut-party-header-panel__title-row">
                <button
                  class="zut-lock-toggle {{#if isLocked}}is-locked{{else}}is-unlocked{{/if}}"
                  type="button"
                  data-lock-toggle="true"
                  title="{{lockToggleTitle}}"
                  aria-label="{{lockToggleLabel}}"
                  {{#unless canToggleLock}}disabled{{/unless}}
                >
                  <i class="{{lockToggleIcon}}" aria-hidden="true"></i>
                  <span class="zut-visually-hidden">{{lockToggleLabel}}</span>
                </button>

                <label class="zut-field__label" for="{{rootId}}-name">
                  {{localize "ZUT.Sheets.Common.Fields.Name"}}
                </label>
              </div>

              <input
                id="{{rootId}}-name"
                class="zut-field__input zut-field__input--title"
                type="text"
                name="name"
                value="{{actor.name}}"
                placeholder="{{localize "ZUT.Sheets.Party.Placeholders.Name"}}"
                {{#unless editable}}disabled{{/unless}}
              >
            </div>

            <div class="zut-party-header-panel__meta-row">
              <div class="zut-party-header-panel__meta-grid">
                <div class="zut-party-meta-card zut-party-meta-card--count">
                  <span class="zut-party-meta-card__label">
                    {{localize "ZUT.Sheets.Party.Fields.MemberCount"}}
                  </span>
                  <span class="zut-party-meta-card__value">{{membersCount}}</span>
                </div>

                <div class="zut-party-meta-card zut-party-meta-card--source">
                  <label class="zut-party-source-control" for="{{rootId}}-skill-source-enabled">
                    <input
                      id="{{rootId}}-skill-source-enabled"
                      class="zut-party-source-control__checkbox"
                      type="checkbox"
                      name="system.details.skillSourceEnabled"
                      {{#if skillSourceEnabled}}checked{{/if}}
                      {{#unless editable}}disabled{{/unless}}
                    >
                    <span class="zut-party-source-control__label">
                      {{localize "ZUT.Sheets.Party.Fields.SkillSource"}}
                    </span>
                  </label>

                  <select
                    id="{{rootId}}-skill-source-target"
                    class="zut-field__input zut-party-source-control__select"
                    name="system.details.skillSourceTarget"
                    {{#unless editable}}disabled{{else}}{{#unless skillSourceEnabled}}disabled{{/unless}}{{/unless}}
                  >
                    {{#each skillSourceOptions as |option|}}
                      <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>
                        {{option.label}}
                      </option>
                    {{/each}}
                  </select>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="zut-sheet__section zut-party-members-panel">
        <div class="zut-party-members-panel__header">
          <div
            class="zut-field__label zut-field__label--section"
            role="heading"
            aria-level="2"
          >
            {{localize "ZUT.Sheets.Party.Sections.Members"}}
          </div>
        </div>

        <div class="zut-field zut-field--panel">
          <div
            class="zut-party-members-panel__body zut-drop-zone"
            data-drop-zone="members"
          >
            {{#if hasMembers}}
              <div class="zut-member-list">
                {{#each members as |member|}}
                  <article class="zut-member-card {{#unless member.exists}}zut-member-card--missing{{/unless}}">
                    <button
                      class="zut-member-card__main"
                      type="button"
                      data-member-open="true"
                      data-member-index="{{member.index}}"
                    >
                      <span class="zut-member-card__media">
                        <span class="zut-member-card__thumb">
                          <img
                            class="zut-member-card__image"
                            src="{{member.img}}"
                            alt="{{member.name}}"
                          >
                        </span>
                      </span>

                      <span class="zut-member-card__content">
                        <span class="zut-member-card__name">{{member.name}}</span>

                        {{#if member.typeLabel}}
                          <span class="zut-member-card__meta zut-muted">{{member.typeLabel}}</span>
                        {{/if}}

                        {{#unless member.exists}}
                          <span class="zut-member-card__missing zut-muted">
                            {{localize "ZUT.Party.Members.MissingActorLabel"}}
                          </span>
                        {{/unless}}
                      </span>
                    </button>

                    <button
                      class="zut-inline-icon-button zut-member-card__remove"
                      type="button"
                      title="{{localize "ZUT.Sheets.Party.Actions.RemoveMember"}}"
                      aria-label="{{localize "ZUT.Sheets.Party.Actions.RemoveMember"}}"
                      data-member-remove="true"
                      data-member-index="{{member.index}}"
                      {{#unless @root.canEdit}}disabled{{/unless}}
                    >
                      <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    </button>
                  </article>
                {{/each}}
              </div>
            {{else}}
              <div class="zut-empty-state zut-party-members-panel__empty">
                <p class="zut-empty-state__text">
                  {{localize "ZUT.Sheets.Party.Empty.Members"}}
                </p>
              </div>
            {{/if}}
          </div>
        </div>
      </section>

      <section class="zut-sheet__section zut-party-tactical-panel">
        <div class="zut-party-tactical-panel__header">
          <div
            class="zut-field__label zut-field__label--section"
            role="heading"
            aria-level="2"
          >
            {{localize "ZUT.Sheets.Party.Sections.Tactical"}}
          </div>
        </div>

        {{#if hasTacticalData}}
          <div class="zut-party-tactical-system-grid">
            {{#each tactical.attributeGroups as |group|}}
              <section class="zut-party-tactical-group" data-attribute-group="{{group.key}}">
                <div class="zut-party-tactical-group__header">
                  <button
                    class="zut-party-rollable zut-party-tactical-group__label"
                    type="button"
                    data-party-roll="true"
                    data-roll-kind="attribute"
                    data-roll-key="{{group.attribute.key}}"
                    {{#unless group.attribute.hasValue}}disabled{{/unless}}
                  >
                    {{group.attribute.label}}
                  </button>

                  <input
                    class="zut-party-tactical-group__value"
                    type="text"
                    value="{{#if group.attribute.hasValue}}{{group.attribute.value}}{{/if}}"
                    readonly
                    tabindex="-1"
                  >
                </div>

                <div class="zut-party-tactical-group__skills">
                  {{#each group.skills as |skill|}}
                    <div class="zut-party-tactical-skill-row">
                      <button
                        class="zut-party-rollable zut-party-tactical-skill-row__label"
                        type="button"
                        data-party-roll="true"
                        data-roll-kind="skill"
                        data-roll-key="{{skill.key}}"
                        {{#unless skill.hasValue}}disabled{{/unless}}
                      >
                        {{skill.label}}
                      </button>

                      <input
                        class="zut-party-tactical-skill-row__value"
                        type="text"
                        value="{{#if skill.hasValue}}{{skill.value}}{{/if}}"
                        readonly
                        tabindex="-1"
                      >
                    </div>
                  {{/each}}
                </div>
              </section>
            {{/each}}
          </div>
        {{else}}
          <div class="zut-empty-state">
            <p class="zut-empty-state__text">
              {{localize "ZUT.Party.Tactical.Empty.UnsupportedMembers"}}
            </p>
          </div>
        {{/if}}
      </section>
    </div>
  </div>
</form>
